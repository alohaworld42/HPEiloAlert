# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values
#   cp .env.example .env
# ─────────────────────────────────────────────

# iLO connection
ILO_HOST=192.168.1.100
ILO_USERNAME=Administrator
ILO_PASSWORD=your-ilo-password
ILO_VERIFY_SSL=false

# Alert settings
ALERT_THRESHOLD=70           # Fan speed % that triggers an alert
ALERT_SERVER_NAME=DL385-Gen11-01
ALERT_INTERVAL_SEC=120       # Check every N seconds (120 = every 2 min)
ALERT_REPEAT_SEC=300         # Re-send alert email while fans stay over threshold (300 = every 5 min)
WEB_PORT=8080                # Dashboard port → http://localhost:8080

# SMTP / email
# ── Option A: Local Postfix (direct delivery, no signup needed) ───────────────
# Sends directly via MX records. No auth required.
# Note: emails to Gmail/Outlook may land in spam without SPF/DKIM.
SMTP_HOST=postfix
SMTP_PORT=587
SMTP_TLS=false
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=alerts@yourdomain.com
EMAIL_TO=you@yourdomain.com
MAIL_DOMAIN=yourdomain.com

# ── Option B: External SMTP (guaranteed delivery) ────────────────────────────
# Uncomment and fill in these lines, then comment out Option A above
# SMTP_HOST=smtp.yourcompany.com
# SMTP_PORT=587
# SMTP_TLS=true
# SMTP_USERNAME=alerts@yourcompany.com
# SMTP_PASSWORD=your-smtp-password
# EMAIL_FROM=alerts@yourcompany.com
# EMAIL_TO=infra-team@yourcompany.com  # Comma-separated for multiple recipients
